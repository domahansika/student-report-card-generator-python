        "import numpy as np\n",
        "def student_grade(average):\n",
        "  if average>=90:\n",
        "    return \"O\"\n",
        "  elif average>=80:\n",
        "    return \"A\"\n",
        "  elif average>=70:\n",
        "    return \"B\"\n",
        "  elif average>=60:\n",
        "    return \"C\"\n",
        "  elif average>=50:\n",
        "    return \"D\"\n",
        "  else:\n",
        "    return \"F\"\n",
        "n=int(input(\"Enter number of students: \"))\n",
        "students=[]\n",
        "for i in range(n):\n",
        "  print(f\"\\nEnter details of student{i+1}: \")\n",
        "  name=input(\"Enter student name: \")\n",
        "  rollno=input(\"Enter student rollno: \")\n",
        "  marks=[]\n",
        "  for j in range(1,7):\n",
        "    mark=float(input(f\"Enter marks for {j} Subject: \"))\n",
        "    marks.append(mark)\n",
        "  marks_array=np.array(marks)\n",
        "  total=np.sum(marks_array)\n",
        "  average=np.mean(marks_array)\n",
        "  grade=student_grade(average)\n",
        "  students.append({\"name\": name, \"marks\": marks,\"total\": total,\"average\": average,\"grade\": grade})\n",
        "topper=max(students, key=lambda x: x[\"total\"])\n",
        "print(\"\\n--------STUDENT REPORT CARD GENERATOR--------\")\n",
        "for s in students:\n",
        "  print(f\"\\nName: {s['name']}\")\n",
        "  print(\"Marks in 6 subjects:\",\"  \".join((str(int(m)) for m in s['marks'])))\n",
        "  print(f\"Total Marks: {s['total']}\")\n",
        "  print(f\"Average Marks: {s['average']: .2f}\")\n",
        "  print(f\"Grade: {s['grade']}\")\n",
        "print(\"\\n------CLASS TOPPER------\")\n",
        "print(f\"Topper Name: {topper['name']}\")\n",
        "print(f\"Total Marks: {topper['total']}\")\n",
        "print(f\"Average Marks: {topper['average']: .2f}\")\n",
        "print(f\"Grade: {topper['grade']}\")"
